{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.indream.ai/schemas/editor-state.v1.schema.json",
  "title": "IndreamEditorStateV1",
  "type": "object",
  "required": [
    "compositionWidth",
    "compositionHeight",
    "timebaseTicksPerSecond",
    "tracks",
    "assets",
    "items",
    "transitions"
  ],
  "properties": {
    "compositionWidth": {
      "type": "integer",
      "minimum": 50,
      "maximum": 1920
    },
    "compositionHeight": {
      "type": "integer",
      "minimum": 50,
      "maximum": 1920
    },
    "timebaseTicksPerSecond": {
      "type": "integer",
      "const": 240000
    },
    "outputRatio": {
      "type": "string",
      "enum": ["16:9", "9:16", "1:1", "4:3", "3:4", "custom"]
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/track"
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/imageAsset"
          },
          {
            "$ref": "#/definitions/videoAsset"
          },
          {
            "$ref": "#/definitions/gifAsset"
          },
          {
            "$ref": "#/definitions/audioAsset"
          },
          {
            "$ref": "#/definitions/captionAsset"
          },
          {
            "$ref": "#/definitions/lottieAsset"
          }
        ]
      }
    },
    "items": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "$ref": "#/definitions/imageItem"
          },
          {
            "$ref": "#/definitions/videoItem"
          },
          {
            "$ref": "#/definitions/gifItem"
          },
          {
            "$ref": "#/definitions/lottieItem"
          },
          {
            "$ref": "#/definitions/audioItem"
          },
          {
            "$ref": "#/definitions/textItem"
          },
          {
            "$ref": "#/definitions/textTemplateItem"
          },
          {
            "$ref": "#/definitions/captionsItem"
          },
          {
            "$ref": "#/definitions/solidItem"
          },
          {
            "$ref": "#/definitions/illustrationItem"
          },
          {
            "$ref": "#/definitions/effectItem"
          },
          {
            "$ref": "#/definitions/filterItem"
          },
          {
            "$ref": "#/definitions/chartItem"
          }
        ]
      }
    },
    "transitions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/transition"
      }
    },
    "globalBackground": {
      "$ref": "#/definitions/globalBackground"
    },
    "brandRuntime": {
      "$ref": "#/definitions/brandRuntime"
    },
    "deletedAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "definitions": {
    "primitive": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "baseAsset": {
      "type": "object",
      "required": ["id", "type", "filename", "size", "mimeType"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "number",
          "minimum": 0
        },
        "remoteUrl": {
          "type": ["string", "null"]
        },
        "remoteKey": {
          "type": ["string", "null"]
        },
        "mimeType": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "imageAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": ["type", "width", "height"],
          "properties": {
            "type": {
              "const": "image"
            },
            "width": {
              "type": "number",
              "minimum": 1
            },
            "height": {
              "type": "number",
              "minimum": 1
            }
          }
        }
      ]
    },
    "videoAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": ["type", "durationInSeconds", "hasAudioTrack", "width", "height"],
          "properties": {
            "type": {
              "const": "video"
            },
            "durationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "hasAudioTrack": {
              "type": "boolean"
            },
            "width": {
              "type": "number",
              "minimum": 1
            },
            "height": {
              "type": "number",
              "minimum": 1
            }
          }
        }
      ]
    },
    "gifAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": ["type", "durationInSeconds", "width", "height", "loopBehavior"],
          "properties": {
            "type": {
              "const": "gif"
            },
            "durationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "width": {
              "type": "number",
              "minimum": 1
            },
            "height": {
              "type": "number",
              "minimum": 1
            },
            "loopBehavior": {
              "type": "string",
              "enum": ["finite", "loop"]
            }
          }
        }
      ]
    },
    "audioAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": ["type", "durationInSeconds"],
          "properties": {
            "type": {
              "const": "audio"
            },
            "durationInSeconds": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      ]
    },
    "lottieAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": [
            "type",
            "durationInSeconds",
            "width",
            "height",
            "resourceType"
          ],
          "properties": {
            "type": {
              "const": "lottie"
            },
            "durationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "width": {
              "type": "number",
              "minimum": 1
            },
            "height": {
              "type": "number",
              "minimum": 1
            },
            "resourceType": {
              "type": "string",
              "enum": ["lottie", "svg"]
            },
            "resourceJson": {
              "type": ["object", "null"],
              "additionalProperties": true
            },
            "resourceComponentId": {
              "type": ["string", "null"]
            },
            "materialConfig": {
              "type": ["object", "null"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "captionAsset": {
      "allOf": [
        {
          "$ref": "#/definitions/baseAsset"
        },
        {
          "type": "object",
          "required": ["type", "captions", "timingGranularity"],
          "properties": {
            "type": {
              "const": "caption"
            },
            "captions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "timingGranularity": {
              "type": "string",
              "enum": ["word", "line"]
            }
          }
        }
      ]
    },
    "track": {
      "type": "object",
      "required": ["id", "items", "hidden", "muted"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "hidden": {
          "type": "boolean"
        },
        "muted": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "animationSpec": {
      "type": "object",
      "required": ["type", "durationTicks"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["fade", "slide-up", "slide-down", "slide-left", "slide-right", "zoom-in", "zoom-out"]
        },
        "durationTicks": {
          "type": "integer",
          "minimum": 1
        },
        "easing": {
          "type": "string",
          "enum": ["linear", "ease-in", "ease-out", "ease-in-out"]
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/primitive"
          }
        }
      },
      "additionalProperties": true
    },
    "clipAnimations": {
      "type": "object",
      "properties": {
        "in": {
          "$ref": "#/definitions/animationSpec"
        },
        "out": {
          "$ref": "#/definitions/animationSpec"
        }
      },
      "additionalProperties": false
    },
    "captionAnimationSpec": {
      "type": "object",
      "required": ["type", "durationTicks"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "converge",
            "elastic-pop",
            "typewriter",
            "lay-down",
            "center-type-out",
            "curtain-close",
            "jitter",
            "rainbow",
            "sweep-shine"
          ]
        },
        "durationTicks": {
          "type": "integer",
          "minimum": 1
        },
        "easing": {
          "type": "string",
          "enum": ["linear", "ease-in", "ease-out", "ease-in-out"]
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/primitive"
          }
        }
      },
      "additionalProperties": true
    },
    "captionClipAnimations": {
      "type": "object",
      "properties": {
        "in": {
          "$ref": "#/definitions/captionAnimationSpec"
        },
        "out": {
          "$ref": "#/definitions/captionAnimationSpec"
        },
        "loop": {
          "$ref": "#/definitions/captionAnimationSpec"
        }
      },
      "additionalProperties": false
    },
    "keyframePoint": {
      "type": "object",
      "required": ["timeTicks", "value"],
      "properties": {
        "timeTicks": {
          "type": "integer",
          "minimum": 0
        },
        "value": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "animatedNumberTrack": {
      "type": "object",
      "required": ["value", "keyframes"],
      "properties": {
        "value": {
          "type": "number"
        },
        "keyframes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/keyframePoint"
          }
        }
      },
      "additionalProperties": false
    },
    "timelineItemBase": {
      "type": "object",
      "required": [
        "id",
        "type",
        "durationTicks",
        "startTicks",
        "isDraggingInTimeline"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "durationTicks": {
          "type": "integer",
          "minimum": 1
        },
        "startTicks": {
          "type": "integer",
          "minimum": 0
        },
        "isDraggingInTimeline": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "geometryItemBase": {
      "type": "object",
      "required": [
        "top",
        "left",
        "width",
        "height",
        "scaleX",
        "scaleY",
        "opacity"
      ],
      "properties": {
        "top": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "left": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "width": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "height": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "scaleX": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "scaleY": {
          "$ref": "#/definitions/animatedNumberTrack"
        },
        "opacity": {
          "$ref": "#/definitions/animatedNumberTrack"
        }
      },
      "additionalProperties": true
    },
    "baseItem": {
      "allOf": [
        {
          "$ref": "#/definitions/timelineItemBase"
        },
        {
          "$ref": "#/definitions/geometryItemBase"
        }
      ]
    },
    "imageItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": ["type", "assetId", "keepAspectRatio", "borderRadius", "rotation"],
          "properties": {
            "type": {
              "const": "image"
            },
            "assetId": {
              "type": "string",
              "minLength": 1
            },
            "stickerId": {
              "type": ["string", "null"],
              "minLength": 1
            },
            "stickerVersion": {
              "type": ["integer", "null"],
              "minimum": 1
            },
            "keepAspectRatio": {
              "type": "boolean"
            },
            "borderRadius": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropLeft": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropTop": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropRight": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropBottom": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            }
          }
        }
      ]
    },
    "videoItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "assetId",
            "keepAspectRatio",
            "borderRadius",
            "rotation",
            "videoStartFromInSeconds",
            "decibelAdjustment",
            "playbackRate",
            "audioFadeInDurationInSeconds",
            "audioFadeOutDurationInSeconds"
          ],
          "properties": {
            "type": {
              "const": "video"
            },
            "assetId": {
              "type": "string",
              "minLength": 1
            },
            "keepAspectRatio": {
              "type": "boolean"
            },
            "borderRadius": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "videoStartFromInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "decibelAdjustment": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "playbackRate": {
              "type": "number",
              "minimum": 0.01
            },
            "audioFadeInDurationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "audioFadeOutDurationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "cropLeft": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropTop": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropRight": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropBottom": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            }
          }
        }
      ]
    },
    "gifItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "assetId",
            "keepAspectRatio",
            "borderRadius",
            "rotation",
            "gifStartFromInSeconds",
            "playbackRate"
          ],
          "properties": {
            "type": {
              "const": "gif"
            },
            "assetId": {
              "type": "string",
              "minLength": 1
            },
            "keepAspectRatio": {
              "type": "boolean"
            },
            "borderRadius": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "gifStartFromInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "playbackRate": {
              "type": "number",
              "minimum": 0.01
            },
            "cropLeft": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropTop": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropRight": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "cropBottom": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            }
          }
        }
      ]
    },
    "lottieItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "assetId",
            "keepAspectRatio",
            "rotation",
            "lottieStartFromInSeconds",
            "playbackRate"
          ],
          "properties": {
            "type": {
              "const": "lottie"
            },
            "assetId": {
              "type": "string",
              "minLength": 1
            },
            "keepAspectRatio": {
              "type": "boolean"
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "lottieStartFromInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "playbackRate": {
              "type": "number",
              "minimum": 0.01
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            }
          }
        }
      ]
    },
    "audioItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "assetId",
            "audioStartFromInSeconds",
            "decibelAdjustment",
            "playbackRate",
            "audioFadeInDurationInSeconds",
            "audioFadeOutDurationInSeconds"
          ],
          "properties": {
            "type": {
              "const": "audio"
            },
            "assetId": {
              "type": "string",
              "minLength": 1
            },
            "audioStartFromInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "decibelAdjustment": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "playbackRate": {
              "type": "number",
              "minimum": 0.01
            },
            "audioFadeInDurationInSeconds": {
              "type": "number",
              "minimum": 0
            },
            "audioFadeOutDurationInSeconds": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      ]
    },
    "textItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "text",
            "color",
            "align",
            "fontFamily",
            "fontStyle",
            "fontSize",
            "lineHeight",
            "letterSpacing",
            "resizeOnEdit",
            "direction",
            "strokeWidth",
            "strokeColor"
          ],
          "properties": {
            "type": {
              "const": "text"
            },
            "text": {
              "type": "string"
            },
            "color": {
              "type": "string"
            },
            "align": {
              "type": "string",
              "enum": ["left", "center", "right"]
            },
            "fontFamily": {
              "type": "string"
            },
            "fontStyle": {
              "type": "object",
              "required": ["variant", "weight"],
              "properties": {
                "variant": {
                  "type": "string"
                },
                "weight": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "fontSize": {
              "type": "number",
              "minimum": 1
            },
            "lineHeight": {
              "type": "number",
              "minimum": 0
            },
            "letterSpacing": {
              "type": "number"
            },
            "resizeOnEdit": {
              "type": "boolean"
            },
            "direction": {
              "type": "string",
              "enum": ["ltr", "rtl"]
            },
            "strokeWidth": {
              "type": "number",
              "minimum": 0
            },
            "strokeColor": {
              "type": "string"
            },
            "background": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object",
                  "required": ["color", "horizontalPadding", "borderRadius"],
                  "properties": {
                    "color": {
                      "type": "string"
                    },
                    "horizontalPadding": {
                      "type": "number",
                      "minimum": 0
                    },
                    "borderRadius": {
                      "type": "number",
                      "minimum": 0
                    }
                  },
                  "additionalProperties": true
                }
              ]
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            },
            "captionAnimations": {
              "$ref": "#/definitions/captionClipAnimations"
            }
          }
        }
      ]
    },
    "textTemplateItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": ["type", "schemaVersion", "templateId", "templateCategory", "nodes"],
          "properties": {
            "type": {
              "const": "text-template"
            },
            "schemaVersion": {
              "type": "integer",
              "const": 2
            },
            "templateId": {
              "type": "string"
            },
            "templateCategory": {
              "type": "string"
            },
            "nodes": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["image", "text"]
                  }
                },
                "additionalProperties": true
              }
            },
            "rotation": {
              "$ref": "#/definitions/animatedNumberTrack"
            },
            "animations": {
              "$ref": "#/definitions/clipAnimations"
            }
          }
        }
      ]
    },
    "captionsItem": {
      "allOf": [
        {
          "$ref": "#/definitions/baseItem"
        },
        {
          "type": "object",
          "required": [
            "type",
            "assetId",
            "fontFamily",
            "fontStyle",
            "lineHeight",
            "letterSpacing",
            "fontSize",
            "align",
            "color",
            "highlightColor",
            "strokeWidth",
            "strokeColor",
            "direction",
            "pageDurationInMilliseconds",
            "captionStartInSeconds",
            "maxLines",
            "source",
            "captionGroupId",
            "background"
          ],
          "properties": {
            "type": {
              "const": "captions"
            },
            "assetId": {
              "type": "string"
            },
            "fontFamily": {
              "type": "string"
            },
            "fontStyle": {
              "type": "object",
              "required": ["variant", "weight"],
              "properties": {
                "variant": {
                  "type": "string"
                },
                "weight": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "lineHeight": {
