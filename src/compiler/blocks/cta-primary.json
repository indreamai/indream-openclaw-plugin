{
  "$id": "block:cta-primary",
  "description": "Strong call-to-action: large headline + CTA badge + background media. All ratios.",
  "supportedRatios": ["16:9", "9:16", "1:1", "4:3", "3:4"],
  "requiredSlots": [],
  "optionalSlots": ["primary"],
  "overridableFields": ["headline", "ctaText", "accentColor", "bgColor"],
  "defaults": {
    "headline": "Get Started Today",
    "ctaText": "Learn More",
    "accentColor": "#ffcc00",
    "bgColor": "#111111"
  },
  "skeleton": {
    "tracks": {
      "{sceneId}-bg": [
        {
          "id": "{sceneId}-bg",
          "type": "solid",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "color": "{bgColor}",
          "size": { "width": "{compositionWidth}", "height": "{compositionHeight}" },
          "position": { "x": 0, "y": 0 },
          "zIndex": 0
        }
      ],
      "{sceneId}-text": [
        {
          "id": "{sceneId}-headline",
          "type": "text",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "text": { "content": "{headline}", "fontWeight": 700, "fontSize": 88, "color": "#ffffff", "align": "center" },
          "size": { "width": 0.88, "height": 300 },
          "position": { "x": 0.06, "y": 0.28 },
          "zIndex": 2,
          "animation": { "in": "zoom-in" }
        },
        {
          "id": "{sceneId}-cta",
          "type": "text",
          "startMs": 120,
          "durationMs": "{durationMs}",
          "text": { "content": "{ctaText}", "fontWeight": 700, "fontSize": 52, "color": "{bgColor}", "align": "center" },
          "size": { "width": 0.4, "height": 100 },
          "position": { "x": 0.3, "y": 0.62 },
          "color": "{accentColor}",
          "zIndex": 3,
          "animation": { "in": "fade" }
        }
      ]
    }
  }
}
