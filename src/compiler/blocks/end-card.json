{
  "$id": "block:end-card",
  "description": "Closing end card with logo/brand area, final message, and CTA. All ratios.",
  "supportedRatios": ["16:9", "9:16", "1:1", "4:3", "3:4"],
  "requiredSlots": [],
  "optionalSlots": ["logo"],
  "overridableFields": ["headline", "ctaText", "accentColor", "bgColor"],
  "defaults": {
    "headline": "Thank You for Watching",
    "ctaText": "Follow for More",
    "accentColor": "#3b82f6",
    "bgColor": "#0a0a0a"
  },
  "skeleton": {
    "tracks": {
      "{sceneId}-bg": [
        {
          "id": "{sceneId}-bg",
          "type": "solid",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "color": "{bgColor}",
          "size": { "width": "{compositionWidth}", "height": "{compositionHeight}" },
          "position": { "x": 0, "y": 0 },
          "zIndex": 0
        }
      ],
      "{sceneId}-text": [
        {
          "id": "{sceneId}-headline",
          "type": "text",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "text": { "content": "{headline}", "fontWeight": 700, "fontSize": 80, "color": "#ffffff", "align": "center" },
          "size": { "width": 0.8, "height": 200 },
          "position": { "x": 0.1, "y": 0.36 },
          "zIndex": 2,
          "animation": { "in": "fade" }
        },
        {
          "id": "{sceneId}-cta",
          "type": "text",
          "startMs": 100,
          "durationMs": "{durationMs}",
          "text": { "content": "{ctaText}", "fontWeight": 600, "fontSize": 52, "color": "{accentColor}", "align": "center" },
          "size": { "width": 0.7, "height": 120 },
          "position": { "x": 0.15, "y": 0.6 },
          "zIndex": 2,
          "animation": { "in": "slide-up" }
        }
      ]
    }
  }
}
