{
  "$id": "block:quote-card",
  "description": "Large pull-quote with attribution. Optional portrait photo. All ratios.",
  "supportedRatios": ["16:9", "9:16", "1:1", "4:3", "3:4"],
  "requiredSlots": [],
  "optionalSlots": ["portrait"],
  "overridableFields": ["quote", "attribution", "accentColor", "bgColor"],
  "defaults": {
    "quote": "Your inspiring quote goes here.",
    "attribution": "— Author Name",
    "accentColor": "#f59e0b",
    "bgColor": "#111111"
  },
  "skeleton": {
    "tracks": {
      "{sceneId}-bg": [
        {
          "id": "{sceneId}-bg",
          "type": "solid",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "color": "{bgColor}",
          "size": { "width": "{compositionWidth}", "height": "{compositionHeight}" },
          "position": { "x": 0, "y": 0 },
          "zIndex": 0
        }
      ],
      "{sceneId}-accent": [
        {
          "id": "{sceneId}-mark",
          "type": "text",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "text": { "content": "\u201c", "fontWeight": 900, "fontSize": 200, "color": "{accentColor}", "align": "left" },
          "size": { "width": 0.2, "height": 220 },
          "position": { "x": 0.06, "y": 0.12 },
          "opacity": 0.3,
          "zIndex": 1
        }
      ],
      "{sceneId}-text": [
        {
          "id": "{sceneId}-quote",
          "type": "text",
          "startMs": 0,
          "durationMs": "{durationMs}",
          "text": { "content": "{quote}", "fontWeight": 500, "fontSize": 58, "color": "#ffffff", "align": "left", "lineHeight": 1.4 },
          "size": { "width": 0.78, "height": 400 },
          "position": { "x": 0.11, "y": 0.28 },
          "zIndex": 2,
          "animation": { "in": "fade" }
        },
        {
          "id": "{sceneId}-attr",
          "type": "text",
          "startMs": 120,
          "durationMs": "{durationMs}",
          "text": { "content": "{attribution}", "fontWeight": 400, "fontSize": 40, "color": "{accentColor}", "align": "left" },
          "size": { "width": 0.6, "height": 80 },
          "position": { "x": 0.11, "y": 0.76 },
          "zIndex": 2,
          "animation": { "in": "fade" }
        }
      ]
    }
  }
}
